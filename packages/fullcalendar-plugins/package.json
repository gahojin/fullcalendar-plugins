{
  "name": "@gahojin-inc/fullcalendar-plugins",
  "version": "2026.4.2",
  "description": "FullCalendar Plugins",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/fullcalendar-plugins.git",
    "directory": "packages/fullcalendar-plugins"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "keywords": [
    "fullcalendar",
    "date-fns",
    "timezone"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./date-fns-timezone": {
      "types": "./dist/date-fns-timezone.d.ts",
      "import": "./dist/date-fns-timezone.js"
    }
  },
  "scripts": {
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "prepack": "cp ../../README.md ./",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "check": "tsc --noEmit",
    "check:packagejson": "attw --pack --profile esm-only .",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "@fullcalendar/core": "6.1.20",
    "@date-fns/tz": "1.4.1",
    "date-fns": "4.1.0"
  },
  "peerDependencies": {
    "@fullcalendar/core": "^6",
    "@date-fns/tz": "^1",
    "date-fns": "^4"
  },
  "peerDependenciesMeta": {
    "@date-fns/tz": {
      "optional": true
    },
    "date-fns": {
      "optional": true
    }
  }
}
